# Copy to .env.local and adjust.

# Seed mode (default in development): in-memory store + demo data.
# Set to 0 to load/save via REST API.
NEXT_PUBLIC_USE_SEED=1

# Backend base URL (required when USE_SEED=0). No trailing slash.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Legacy alias also supported:
# NEXT_PUBLIC_SYNC_API_URL=http://localhost:4000
